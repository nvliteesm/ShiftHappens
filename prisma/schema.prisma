generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  hashedPassword  String
  image           String?
  isPlatformAdmin Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts               Account[]
  sessions               Session[]
  memberships            Membership[]
  invitationsSent        InvitationToken[]
  tasksCreated           Task[]
  taskAssignedBy         TaskAssignment[] @relation("AssignedByUser")
  certificationsVerified Certification[]        @relation("CertificationVerifier")
  eligibilityOverrides   EligibilityOverride[]  @relation("EligibilityOverrider")
  auditLogs              AuditLog[]
  notifications          Notification[]
}

model Organization {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  industry            String?
  description         String?
  logo                String?
  address             String?
  templateId          String?
  status              String   @default("active")
  subscriptionTier    String   @default("free")   // "free" | "pro" | "enterprise"
  // Stripe billing (test mode). Set by the checkout webhook, not by users.
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?  // "active" | "past_due" | "canceled" | ... (mirrors Stripe)
  billingInterval      String?  // "month" | "year"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships      Membership[]
  departments      Department[]
  invitationTokens InvitationToken[]
  roles            Role[]
  companySettings  CompanySettings?
  tasks            Task[]
  auditLogs        AuditLog[]
  workRules        WorkRule[]
}

model Membership {
  id                String   @id @default(cuid())
  userId            String
  organizationId    String
  role              String   @default("staff")
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customRoleId      String?
  employmentType    String?  // "casual" | "full_time"

  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customRole            Role? @relation("MembershipCustomRole", fields: [customRoleId], references: [id], onDelete: SetNull)
  departmentMemberships DepartmentMembership[]
  taskAssignments       TaskAssignment[]
  availabilities        Availability[]
  availabilityOverrides AvailabilityOverride[]
  certifications        Certification[]
  eligibilityOverrides  EligibilityOverride[]

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Department {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workRules             WorkRule[]             @relation("WorkRuleDepartment")
  departmentMemberships DepartmentMembership[]
  tasks                 Task[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model DepartmentMembership {
  id           String   @id @default(cuid())
  membershipId String
  departmentId String
  createdAt    DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([membershipId, departmentId])
  @@index([departmentId])
}

model InvitationToken {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           String
  departmentId   String?
  token          String    @unique
  invitedById    String
  expires        DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([token])
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  displayLabel   String
  description    String?
  isDefault      Boolean  @default(false)
  isSystemRole   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberCustomRoles Membership[]     @relation("MembershipCustomRole")
  rolePermissions RolePermission[]
  workRules       WorkRule[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id          String @id @default(cuid())
  name        String @unique
  description String
  category    String

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
}

model CompanySettings {
  id                      String   @id @default(cuid())
  organizationId          String   @unique
  allocationMode          String   @default("manual")
  taskAcceptanceMode      String   @default("auto_accept")
  breakRuleHoursWorked    Int      @default(8)
  breakRuleBreakHours     Int      @default(1)
  operatingHoursStart     Int      @default(6)
  operatingHoursEnd       Int      @default(22)
  smartAllocationWeights  String?
  notificationPreferences String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Task {
  id                String    @id @default(cuid())
  organizationId    String
  departmentId      String?
  title             String
  description       String?
  requiredHeadcount Int       @default(1)
  status            String    @default("open")
  priority          String    @default("medium")
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  isRecurring       Boolean   @default(false)
  recurringPattern  String?
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy    User             @relation(fields: [createdById], references: [id])
  assignments  TaskAssignment[]
  eligibilityOverrides EligibilityOverride[]

  @@index([organizationId])
  @@index([departmentId])
  @@index([status])
}

model TaskAssignment {
  id              String    @id @default(cuid())
  taskId          String
  membershipId    String
  status          String    @default("pending")
  rejectionReason String?
  rejectionNotes  String?
  clockInTime     DateTime?
  clockOutTime    DateTime?
  assignedById    String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  assignedBy User       @relation("AssignedByUser", fields: [assignedById], references: [id])

  @@unique([taskId, membershipId])
  @@index([taskId])
  @@index([membershipId])
  @@index([status])
}

model Availability {
  id           String   @id @default(cuid())
  membershipId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, dayOfWeek])
  @@index([membershipId])
}

model AvailabilityOverride {
  id           String   @id @default(cuid())
  membershipId String
  date         DateTime
  isAvailable  Boolean  @default(false)
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, date])
  @@index([membershipId])
}

model Certification {
  id           String    @id @default(cuid())
  membershipId String
  name         String
  issuedDate   DateTime
  expiryDate   DateTime?
  documentUrl  String?
  status       String    @default("pending")
  verifiedById String?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  verifiedBy User?      @relation("CertificationVerifier", fields: [verifiedById], references: [id])

  @@index([membershipId])
  @@index([status])
}

model EligibilityOverride {
  id             String   @id @default(cuid())
  taskId         String
  membershipId   String
  overriddenById String
  reason         String
  ruleOverridden String
  createdAt      DateTime @default(now())

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  overriddenBy User     @relation("EligibilityOverrider", fields: [overriddenById], references: [id])

  @@index([taskId])
  @@index([membershipId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  details        Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model WorkRule {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  type            String   // "break_interval" | "max_hours_daily" | "max_hours_weekly"
  roleId          String?  // null = applies to all staff
  departmentId    String?  // null = applies to all departments
  hoursThreshold  Float?   // for break_interval: every X hours
  breakHours      Float?   // for break_interval: require Y hours break
  maxHours        Float?   // for max_hours_daily/weekly: cap at X hours
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  department   Department?  @relation("WorkRuleDepartment", fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model IndustryTemplate {
  id             String   @id @default(cuid())
  name           String   @unique
  icon           String   @default("Building")
  description    String
  departments    Json     // Array of {name, description, color}
  workRules      Json     // Array of {name, type, hoursThreshold?, breakHours?, maxHours?, reason}
  certifications Json     // Array of strings
  isActive       Boolean  @default(true)
  isAiGenerated  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}